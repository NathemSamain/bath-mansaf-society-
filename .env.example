# Supabase credentials (get from Dashboard → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Alpha Vantage API key (get from https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-here

# Note: Use the service_role key for Python scripts (bypasses RLS)
# The anon key is only for frontend/client-side code
